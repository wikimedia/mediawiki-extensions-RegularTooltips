{
	"name": "RegularTooltips",
	"version": "1.0.0",
	"author": [
		"Sanjay Thiyagarajan"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:RegularTooltips",
	"descriptionmsg": "regulartooltips-desc",
	"type": "parserhook",
	"load_composer_autoloader": true,
	"MessagesDirs": {
		"RegularTooltips": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"RegularTooltipsMagic": "RegularTooltips.i18n.magic.php"
	},
	"AutoloadClasses": {
		"RegularTooltipsHooks": "src/RegularTooltipsHooks.php",
		"RegularTooltipsParser": "src/RegularTooltipsParser.php"
	},
	"ResourceModules": {
		"ext.RegularTooltips": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"packageFiles": [
				"lib/RegularTooltips.js",
				"lib/InfoTooltip.vue",
				{
					"name": "lib/icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconInfo"
					]
				}
			],
			"codexComponents": [
				"CdxToggleButton",
				"CdxPopover",
				"CdxIcon"
			],
			"messages": [
				"regulartooltips-info-label"
			],
			"dependencies": [
				"vue"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "RegularTooltips"
	},
	"Hooks": {
		"ParserFirstCallInit": "RegularTooltipsHooks::registerParserFunctions"
	},
	"requires": {
		"MediaWiki": ">= 1.44.0"
	},
	"manifest_version": 1
}
